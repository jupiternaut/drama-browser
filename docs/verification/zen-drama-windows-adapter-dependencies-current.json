{
  "schema": "zen-drama-windows-adapter-dependencies.v1",
  "documentedAt": "2026-06-18",
  "scope": {
    "thisChangeRequiresMacProductPathVerification": true,
    "thisChangeRequiresWindowsRuntimeVerification": false,
    "crossPlatformClaimAllowed": false,
    "reason": "The current delivery target is macOS source-built Zen on this machine. Windows support is documented as an adapter dependency surface, not as a verified runtime surface for this change."
  },
  "windowsAdapter": {
    "target": "Zen Browser Windows x64 package",
    "installRoot": "%LOCALAPPDATA%\\Programs\\DramaZen",
    "zenExecutable": "%LOCALAPPDATA%\\Programs\\DramaZen\\zen\\zen.exe",
    "chromeResourcePath": "zen\\browser\\chrome\\browser\\content\\browser\\drama\\app\\index.html",
    "profileRoot": "%LOCALAPPDATA%\\Programs\\DramaZen\\profile",
    "runtimePort": 3198,
    "plotPilotPort": 8005
  },
  "requiredTools": [
    {
      "name": "PowerShell",
      "version": "Windows PowerShell 5.1 or newer",
      "usedBy": [
        "scripts/package-zen-drama-win.ps1",
        "scripts/install-zen-drama-package.ps1",
        "scripts/verify-zen-drama-win-marionette.ps1"
      ]
    },
    {
      "name": "Bun",
      "version": "1.3.10 or compatible",
      "usedBy": [
        "browser shell build",
        "runtime bundle",
        "packaged runtime launch"
      ]
    },
    {
      "name": "Python",
      "version": "3.11 or compatible",
      "usedBy": [
        "Marionette product-path verifier",
        "screenshot analysis with Pillow"
      ]
    },
    {
      "name": "Pillow",
      "version": "latest compatible",
      "usedBy": [
        "PNG black/blank/low-variation screenshot detection"
      ]
    },
    {
      "name": "7-Zip",
      "version": "bundled on windows-latest or installed separately",
      "usedBy": [
        "extracting official Zen Windows installer into a packageable bin tree"
      ]
    }
  ],
  "packageInputs": [
    {
      "name": "Zen Windows bin tree",
      "source": "scripts/prepare-zen-windows-bin.ps1 from https://github.com/zen-browser/desktop/releases/latest/download/zen.installer.exe or an explicit -ZenBinDir",
      "mustContain": [
        "zen.exe",
        "browser",
        "browser\\chrome"
      ]
    },
    {
      "name": "Drama browser shell build",
      "source": "apps\\drama-browser-shell\\dist",
      "mustContain": [
        "index.html",
        "assets"
      ]
    },
    {
      "name": "Drama runtime bundle",
      "source": "apps\\drama-runtime\\src\\server.ts built to runtime\\drama-runtime.js",
      "mustContain": [
        "runtime\\drama-runtime.js"
      ]
    }
  ],
  "commands": {
    "prepareZenBin": "bun run zen:drama:prepare-zen-bin:win -- -ZenInstallerUrl \"https://github.com/zen-browser/desktop/releases/latest/download/zen.installer.exe\" -OutputDir \"dist\\zen-windows-bin\" -Force",
    "package": "bun run zen:drama:package:win -- -ZenBinDir \"dist\\zen-windows-bin\" -NoPlotPilotBundle -Zip",
    "install": "bun run zen:drama:install:win",
    "installedPanelVerifier": "bun run zen:drama:install:verify:panel:win",
    "runtimeProductGate": "bun run zen:drama:windows-gate -- -PackageZip \"dist\\zen-drama-win-x64.zip\" -AllSurfaces -CheckRouteSwitches"
  },
  "evidencePolicy": {
    "macEvidenceCanSatisfyThisChange": true,
    "windowsDependencyFileCanSatisfyThisChange": true,
    "windowsDependencyFileCanSatisfyCrossPlatformRuntimeClaim": false,
    "requiredBeforeCrossPlatformClaim": [
      "docs\\verification\\zen-drama-windows-product-gate-current.json with ok=true",
      "docs\\verification\\zen-drama-win-marionette-summary-current.json with ok=true",
      "PNG screenshots for graph, plm, and crew from Windows Zen"
    ]
  }
}
