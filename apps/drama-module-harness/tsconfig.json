{
  "compilerOptions": {
    "types": ["vite/client"],
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@drama/core": ["../../packages/drama-core/src/index.ts"],
      "@drama/core/*": ["../../packages/drama-core/src/*"],
      "@drama/crew": ["../../packages/drama-crew/src/index.ts"],
      "@drama/crew/*": ["../../packages/drama-crew/src/*"],
      "@drama/graph": ["../../packages/drama-graph/src/index.ts"],
      "@drama/graph/*": ["../../packages/drama-graph/src/*"],
      "@drama/graph-ui": ["../../packages/drama-graph-ui/src/index.ts"],
      "@drama/graph-ui/*": ["../../packages/drama-graph-ui/src/*"],
      "@drama/host": ["../../packages/drama-host/src/index.ts"],
      "@drama/host/*": ["../../packages/drama-host/src/*"],
      "@drama/plm": ["../../packages/drama-plm/src/index.ts"],
      "@drama/plm/*": ["../../packages/drama-plm/src/*"],
      "@drama/plm-ui": ["../../packages/drama-plm-ui/src/index.ts"],
      "@drama/plm-ui/*": ["../../packages/drama-plm-ui/src/*"],
      "@drama/ui": ["../../packages/drama-ui/src/index.ts"],
      "@drama/ui/*": ["../../packages/drama-ui/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
